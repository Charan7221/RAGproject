# =============================================================================
# RAG Document QA System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!
#
# Default: Uses Ollama (free, local, no API key needed)
# Optional: Add API keys for Google Gemini or OpenAI
# =============================================================================

# -----------------------------------------------------------------------------
# LLM & Embeddings API Keys (OPTIONAL)
# -----------------------------------------------------------------------------
# The system uses Ollama by default (no API key required)
# Only add these if you want to use cloud-based LLMs

# Google Gemini API key (OPTIONAL - only if using Gemini instead of Ollama)
# Get your key: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-google-api-key-here
# GEMINI_API_KEY=your-google-api-key-here

# OpenAI API key (OPTIONAL - only if using OpenAI instead of Ollama)
# Get your key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here

# -----------------------------------------------------------------------------
# PostgreSQL Database Configuration
# -----------------------------------------------------------------------------
# These defaults match docker-compose.yml
# Only change if using external PostgreSQL or custom Docker setup

DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_db
DB_USER=rag_user
DB_PASSWORD=rag_password

# For production, use strong passwords and secure connections:
# DB_HOST=your-production-db-host
# DB_SSL_MODE=require

# -----------------------------------------------------------------------------
# Redis Cache Configuration (OPTIONAL - Recommended for Performance)
# -----------------------------------------------------------------------------
# Redis provides 50x faster responses for repeated queries
# Install: brew install redis (macOS) or apt install redis (Linux)
# Docker: docker run -d -p 6379:6379 redis:alpine

# Enable/disable caching (default: true)
CACHE_ENABLED=true

# Redis connection settings (defaults match standard Redis installation)
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache time-to-live in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600

# If Redis is not available, the system will work without caching
# To disable caching: CACHE_ENABLED=false

# -----------------------------------------------------------------------------
# Backend API Configuration (Optional)
# -----------------------------------------------------------------------------

# Backend server host and port
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend Configuration (Optional)
# -----------------------------------------------------------------------------

# API endpoint for React frontend
REACT_APP_API_URL=http://localhost:8000

# For production deployment:
# REACT_APP_API_URL=https://your-production-domain.com

# -----------------------------------------------------------------------------
# Ollama Configuration (Default LLM)
# -----------------------------------------------------------------------------
# Ollama runs locally - no API key needed!
# Install: https://ollama.ai
# Models used: llama3.2:3b (LLM), nomic-embed-text (embeddings)

OLLAMA_BASE_URL=http://localhost:11434

# To use different Ollama models, update config/config.yml
# Available models: ollama list

# Maximum file upload size (in bytes)
# MAX_UPLOAD_SIZE=10485760

# Session timeout (in seconds)
# SESSION_TIMEOUT=3600

# =============================================================================
# End of Configuration
# =============================================================================

