# =============================================================================
# RAG Document QA System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!
#
# Quick start: Get a free Gemini API key at https://aistudio.google.com/apikey
# =============================================================================

# -----------------------------------------------------------------------------
# LLM & Embeddings API Keys
# -----------------------------------------------------------------------------

# Google Gemini API key (REQUIRED for embeddings + LLM)
# Get your key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Alternative env var name (also supported):
# GEMINI_API_KEY=your-google-api-key-here

# OpenAI API key (OPTIONAL - only if using OpenAI embeddings)
# Get your key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here

# -----------------------------------------------------------------------------
# PostgreSQL Database Configuration
# -----------------------------------------------------------------------------
# These defaults match docker-compose.yml
# Only change if using external PostgreSQL or custom Docker setup

DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_db
DB_USER=rag_user
DB_PASSWORD=rag_password

# For production, use strong passwords and secure connections:
# DB_HOST=your-production-db-host
# DB_SSL_MODE=require

# -----------------------------------------------------------------------------
# Backend API Configuration (Optional)
# -----------------------------------------------------------------------------

# Backend server host and port
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend Configuration (Optional)
# -----------------------------------------------------------------------------

# API endpoint for React frontend
REACT_APP_API_URL=http://localhost:8000

# For production deployment:
# REACT_APP_API_URL=https://your-production-domain.com

# -----------------------------------------------------------------------------
# Advanced Configuration (Optional)
# -----------------------------------------------------------------------------

# Ollama configuration (if using local embeddings)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=nomic-embed-text

# Maximum file upload size (in bytes)
# MAX_UPLOAD_SIZE=10485760

# Session timeout (in seconds)
# SESSION_TIMEOUT=3600

# =============================================================================
# End of Configuration
# =============================================================================

